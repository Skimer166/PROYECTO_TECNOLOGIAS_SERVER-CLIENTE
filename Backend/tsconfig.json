{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "nodenext",
    "esModuleInterop": true,
    "target": "esnext",
    "strict": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "types": ["jest", "node"]
  },
  "exclude": [          
    "node_modules",
    "jest.config.ts",
    "eslint.config.mts" 
  ]
}