{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "nodenext",
    "esModuleInterop": true,
    "target": "esnext",
    "strict": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["jest", "node", "passport"]
  },
  "files": ["./src/types/express.d.ts"],
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "jest.config.ts",
    "eslint.config.mts"
  ]
}